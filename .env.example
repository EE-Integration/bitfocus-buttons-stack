# Optional overrides — copy to .env for local builds,
# or set as Portainer stack environment variables.

# Tag for the locally built image (defaults to "latest")
IMAGE_TAG=1.0.0

# Override to build a specific Bitfocus Buttons release.
# Default is set in the Dockerfile ARG. Only needed when upgrading.
# BUTTONS_URL=https://s4-cf.bitfocus.io/builds/buttons/bitfocus-buttons-linux-x64-NNNN-XXXXXXXX.tar.gz
