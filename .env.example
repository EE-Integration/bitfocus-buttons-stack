# Optional overrides.
# - Set IMAGE_TAG in Portainer stack environment variables.
# - Use the remaining values for local image build/push workflows.

# Tag for the locally built image (defaults to "latest")
IMAGE_TAG=1.0.0

# Preferred local release tarball (inside bitfocus-buttons-linux-x64/)
BUTTONS_TARBALL=bitfocus-buttons-linux-x64-5585-918fc50d.tar.gz

# Override to build a specific Bitfocus Buttons release.
# Default is set in the Dockerfile ARG. Only needed when upgrading.
# BUTTONS_URL=https://s4-cf.bitfocus.io/builds/buttons/bitfocus-buttons-linux-x64-NNNN-XXXXXXXX.tar.gz
